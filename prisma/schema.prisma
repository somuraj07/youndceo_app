// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  // Rust-free client — requires a driver adapter in lib/prisma.ts.
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum AssignmentType {
  MCQ
  FILL_IN_BLANK
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MoneyKind {
  EXPENSE
  INCOME
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatarUrl String?
  coverUrl  String?
  bio       String?
  xp        Int      @default(0)
  streak    Int      @default(0)
  rankId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rank            Rank?                  @relation(fields: [rankId], references: [id], onDelete: SetNull)
  accounts        Account[]
  sessions        Session[]
  submissions     AssignmentSubmission[]
  goals           Goal[]
  cashWallet      CashWallet?
  savingsAccounts SavingsAccount[]
  expenses        Expense[]
  sipPlans        SipPlan[]
  newsLikes       NewsLike[]
  notifications   Notification[]
}

model Assignment {
  id            String         @id @default(uuid())
  title         String
  description   String?
  category      String
  type          AssignmentType
  question      String
  options       Json?
  correctAnswer String
  xpReward      Int            @default(100)
  imageUrl      String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  userId       String
  assignmentId String
  answer       String
  isCorrect    Boolean?
  status       SubmissionStatus @default(PENDING)
  xpEarned     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
}

model Rank {
  id        String   @id @default(uuid())
  name      String
  minXp     Int
  maxXp     Int?
  badgeUrl  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Fund {
  id          String   @id @default(uuid())
  name        String
  symbol      String   @unique
  description String?
  category    String
  imageUrl    String?
  price       Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id        String   @id @default(uuid())
  title     String
  body      String
  imageUrl  String?
  videoUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes NewsLike[]
}

model NewsLike {
  id        String   @id @default(uuid())
  newsId    String
  userId    String
  createdAt DateTime @default(now())

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
  @@index([newsId])
  @@index([userId])
}

enum NotificationType {
  NEWS
  ASSIGNMENT
  RESULT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Fee {
  id          String    @id @default(uuid())
  title       String
  amount      Float
  description String?
  dueDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Goal {
  id            String    @id @default(uuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CashWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsAccount {
  id        String   @id @default(uuid())
  userId    String
  name      String
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String    @id @default(uuid())
  userId    String
  title     String
  amount    Float
  category  String
  kind      MoneyKind @default(EXPENSE)
  spentAt   DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spentAt])
  @@index([userId, kind])
}

model SipPlan {
  id            String   @id @default(uuid())
  userId        String
  name          String
  monthlyAmount Float
  expectedRate  Float    @default(12)
  years         Int      @default(10)
  fundSymbol    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
